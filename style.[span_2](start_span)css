body { margin: 0; height: 100vh; overflow: hidden; font-family: sans-serif; background: #000; }
#bg-container { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; }
#active-bg { width: 100%; height: 100%; transition: background 1s ease; background: linear-gradient(45deg, #1a2a6c, #b21f1f, #fdbb2d); }

main { display: flex; justify-content: center; align-items: center; height: 100vh; gap: 20px; }
.glass-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 40px;
    border-radius: 20px;
    color: white;
    cursor: pointer;
    transition: 0.3s;
}
.glass-card:hover { transform: scale(1.05); }
